PORT=8787
HOST=127.0.0.1
PUBLIC_BASE_URL=http://127.0.0.1:8787
SESSION_SECRET=replace-with-a-long-random-value

# LinkedIn OIDC. Create an app in the LinkedIn Developer Portal and add:
# http://127.0.0.1:8787/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8787/auth/linkedin/callback
LINKEDIN_SCOPES=openid profile email
# web is the self-serve LinkedIn OIDC flow. local-pkce requires LinkedIn to enable Native PKCE for your app.
LINKEDIN_OAUTH_FLOW=web

# demo returns local generated jobs and graph data.
# live uses LinkedIn auth for profile and an optional external job source.
CONNECTOR_MODE=demo
JOB_SOURCE_API_URL=
