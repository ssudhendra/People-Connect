PORT=8787
HOST=127.0.0.1
PUBLIC_BASE_URL=http://localhost:8787
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_32_PLUS_CHARACTER_SECRET

# LinkedIn OIDC
# Add both callback URLs in LinkedIn Developer Portal:
# http://localhost:8787/auth/linkedin/callback
# http://127.0.0.1:8787/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=auto
LINKEDIN_SCOPES="openid profile email"
LINKEDIN_OAUTH_FLOW=web

# demo = generated sample jobs/network data
# live = real LinkedIn auth profile + external job source
CONNECTOR_MODE=demo

# Do not use linkedin.com/jobs as an API endpoint.
# Add a real jobs API endpoint here later if needed.
JOB_SOURCE_API_URL=
