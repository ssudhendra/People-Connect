PORT=8787
HOST=127.0.0.1
PUBLIC_BASE_URL=http://localhost:8787
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_32_PLUS_CHARACTER_SECRET

# LinkedIn OIDC
# Add both callback URLs in LinkedIn Developer Portal:
# http://localhost:8787/auth/linkedin/callback
# http://127.0.0.1:8787/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=auto
# Use oidc for "Sign In with LinkedIn using OpenID Connect".
# Use legacy only for older apps that grant r_liteprofile/r_emailaddress.
LINKEDIN_AUTH_TYPE=oidc
LINKEDIN_SCOPES="openid profile email"
LINKEDIN_OAUTH_FLOW=web

# demo = generated sample jobs/network data
# live = real LinkedIn auth profile + external job source
CONNECTOR_MODE=demo

# Exact LinkedIn Jobs-tab data requires an approved LinkedIn Talent/Jobs
# integration or another licensed jobs provider. Do not use linkedin.com/jobs
# as an API endpoint and do not scrape LinkedIn pages.
JOB_SOURCE_API_URL=
JOB_SOURCE_API_KEY=
JOB_SOURCE_AUTH_HEADER=authorization
JOB_SOURCE_PROVIDER_NAME=
REQUIRE_LIVE_JOB_SOURCE=false
